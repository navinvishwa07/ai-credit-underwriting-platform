<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Total Applications</h6>
                <h2><%= loanSummary.totalApplications %></h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Under Review</h6>
                <h2><%= loanSummary.underReview %></h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Approved</h6>
                <h2><%= loanSummary.approvedApplications %></h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Rejected</h6>
                <h2><%= loanSummary.rejectedApplications %></h2>
            </div>
        </div>
    </div>
</div>
