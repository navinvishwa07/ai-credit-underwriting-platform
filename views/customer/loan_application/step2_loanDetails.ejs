<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loan Application | Step 2</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">

    <div class="container">

        <a class="navbar-brand fw-bold" href="/customer/dashboard">
            Rupya AI
        </a>

    </div>

</nav>

<div class="container mt-5">

    <div class="row">


        <div class="col-md-3">

            <div class="card shadow-sm">

                <div class="card-header">
                    <h5>Application Progress</h5>
                </div>

                <div class="card-body">

                    <p class="text-success">✔ Personal Information</p>

                    <p><strong>Step 2</strong> Loan Details</p>

                    <p>○ Employment</p>

                    <p>○ Financial Information</p>

                    <p>○ Credit Information</p>

                    <p>○ Review & Submit</p>

                </div>

            </div>

        </div>


        <div class="col-md-9">

            <div class="card shadow">

                <div class="card-header">

                    <h3>Step 2 - Loan Details</h3>

                    <small class="text-muted">
                        Provide information about the loan you wish to apply for.
                    </small>

                </div>

                <div class="card-body">

                    <form action="/customer/apply-loan/step3" method="GET">

                        <div class="mb-3">

                            <label class="form-label">
                                Loan Type *
                            </label>

                            <select
                                class="form-select border border-dark"
                                name="loanType"
                                required>

                                <option value="">Select Loan Type</option>
                                <option>Personal Loan</option>
                                <option>Home Loan</option>
                                <option>Car Loan</option>
                                <option>Education Loan</option>
                                <option>Business Loan</option>
                                <option>Gold Loan</option>
                                <option>Agricultural Loan</option>
                                <option>Two Wheeler Loan</option>
                                <option>Consumer Durable Loan</option>
                                <option>Medical Loan</option>
                                <option>Travel Loan</option>
                                <option>Wedding Loan</option>
                                <option>Mortgage Loan</option>

                            </select>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Loan Amount Requested (₹) *
                                </label>

                                <input
                                    type="number"
                                    minlength="10000"
                                    maxlength="1000000"
                                    class="form-control border border-dark"
                                    name="loanAmount"
                                    required>

                            </div>

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Loan Tenure (Months) *
                                </label>

                                <input
                                    type="number"
                                    class="form-control border border-dark"
                                    name="loanTenure"
                                    required>

                            </div>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Purpose of Loan *
                            </label>

                            <textarea
                                class="form-control border border-dark"
                                rows="3"
                                name="loanPurpose"
                                required></textarea>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Preferred EMI Date *
                                </label>

                                <select
                                    class="form-select border border-dark"
                                    name="emiDate"
                                    required>

                                    <option value="">Select Date</option>
                                    <option>1st of Every Month</option>
                                    <option>5th of Every Month</option>
                                    <option>10th of Every Month</option>
                                    <option>15th of Every Month</option>
                                    <option>20th of Every Month</option>
                                    <option>25th of Every Month</option>

                                </select>

                            </div>

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Repayment Method *
                                </label>

                                <select
                                    class="form-select border border-dark"
                                    name="repaymentMethod"
                                    required>

                                    <option value="">Select Method</option>
                                    <option>EMI</option>
                                    <option>Bullet Repayment</option>
                                    <option>Quarterly</option>
                                    <option>Bi-Annual</option>
                                    <option>Annual</option>

                                </select>

                            </div>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">
                                Do you have a Co-Applicant? *
                            </label>

                            <select
                                class="form-select border border-dark"
                                name="coApplicant"
                                required>

                                <option value="">Select</option>
                                <option>No</option>
                                <option>Yes</option>

                            </select>

                        </div>

                        <div class="d-flex justify-content-between">

                            <a href="/customer/apply-loan/step1" class="btn btn-secondary">
                                Previous
                            </a>

                            <button
                                type="submit"
                                class="btn btn-primary">
                                Save & Next
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

</body>

</html>
