<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head', { pageTitle: 'Customer Dashboard | Rupya AI' }) %>
</head>

<body class="bg-light">

    <%- include('../partials/navbar') %>

    <div class="container mt-5">

        <div class="mb-4">
            <h1>Customer Dashboard</h1>
            <p class="text-muted">
                Welcome, <%= customer.name %>. Manage your loan applications and track their progress.
            </p>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <h4 class="mb-3">Quick Actions</h4>

                <a href="/customer/apply-loan" class="btn btn-primary me-2">
                    Apply for Loan
                </a>

                <a href="/customer/loan-status" class="btn btn-outline-primary">
                    Track Application
                </a>

            </div>
        </div>

        <%- include('../partials/dashboard_cards', { loanSummary }) %>

        <div class="card shadow-sm">

            <div class="card-header">
                <h4 class="mb-0">Recent Applications</h4>
            </div>

            <div class="card-body">

                <%- include('../partials/application_table', { applications: recentApplications }) %>

            </div>

        </div>

    </div>

    <%- include('../partials/footer') %>

    <%- include('../partials/scripts') %>

</body>

</html>
