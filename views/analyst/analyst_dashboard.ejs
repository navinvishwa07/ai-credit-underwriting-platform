<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head', { pageTitle: 'Analyst Dashboard | Rupya AI' }) %>
</head>

<body class="bg-light">

    <%- include('../partials/navbar') %>

    <div class="container mt-5">

        <div class="mb-4">
            <h1>Analyst Dashboard</h1>
            <p class="text-muted">
                Welcome, <%= analyst.firstName %> <%= analyst.lastName %>. Review and process loan applications.
            </p>
        </div>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6>Total Applications</h6>
                        <h2><%= stats.total %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6>Pending Review</h6>
                        <h2><%= stats.pending %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6>Approved</h6>
                        <h2><%= stats.approved %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6>Rejected</h6>
                        <h2><%= stats.rejected %></h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">

            <div class="card-header">
                <h4 class="mb-0">Loan Applications</h4>
            </div>

            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Application No.</th>
                            <th>Customer Name</th>
                            <th>Loan Type</th>
                            <th>Loan Amount</th>
                            <th>Status</th>
                            <th>Submitted Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% applications.forEach(app => { %>
                            <tr>
                                <td><%= app.application_number %></td>
                                <td><%= app.applicants.first_name %> <%= app.applicants.last_name %></td>
                                <td><%= app.loan_types.loan_type_name %></td>
                                <td>₹<%= Number(app.loan_amount_requested).toLocaleString('en-IN') %></td>
                                <td>
                                    <% if (app.status === 'Approved') { %>
                                        <span class="badge bg-success"><%= app.status %></span>
                                    <% } else if (app.status === 'Rejected') { %>
                                        <span class="badge bg-danger"><%= app.status %></span>
                                    <% } else if (app.status === 'Under Review') { %>
                                        <span class="badge bg-warning text-dark"><%= app.status %></span>
                                    <% } else { %>
                                        <span class="badge bg-secondary"><%= app.status %></span>
                                    <% } %>
                                </td>
                                <td><%= new Date(app.submitted_at).toLocaleDateString('en-IN') %></td>
                                <td>
                                    <a href="/analyst/applications/<%= app.application_id %>/review" class="btn btn-sm btn-primary">View</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

        </div>

    </div>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts') %>

</body>

</html>
